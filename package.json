{
  "name": "uni-research-applications-backend",
  "version": "1.0.0",
  "description": "Backend to manage submissions of research projects on events in a university",
  "type": "module",
  "engines": {
    "bun": "1.3.x"
  },
  "main": "index.js",
  "scripts": {
    "dev": "bun --watch index.js",
    "start": "pm2 start --interpreter ~/.bun/bin/bun index.js",
    "restart": "pm2 restart index.js --update-env",
    "stop": "pm2 stop index.js",
    "checkUpdates": "bunx taze -w",
    "lint": "bun run eslint .",
    "lint:fix": "bun run eslint . --fix",
    "test": "node --experimental-vm-modules $(yarn bin jest) --config ./test/jest.config.js .",
    "test:api": "node --experimental-vm-modules $(yarn bin jest) --config ./test/jest.config.js test/api/"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "no",
  "private": false,
  "keywords": [
    "javascript",
    "bun",
    "express",
    "rest",
    "jest",
    "bdd",
    "eslint",
    "mongodb",
    "mongoose",
    "google-cloud"
  ],
  "author": {
    "name": "Sindélio Henrique Lima",
    "email": "sindelio@gmail.com",
    "url": "https://github.com/sindelio"
  },
  "contributors": [],
  "dependencies": {
    "body-parser": "^2.2.2",
    "celebrate": "^15.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "9.2.4",
    "nodemailer": "^8.0.2",
    "pm2": "^6.0.14"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/bun": "^1.3.10",
    "doctoc": "^2.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-jest": "^29.15.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1"
  }
}
